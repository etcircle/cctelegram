# cc-telegram configuration — copy to ~/.cc-telegram/.env (or ./.env) and edit.
# Only the first two variables are REQUIRED; everything else has a working default.
# See docs/DEPLOYMENT.md for the full env reference.

# --- Required ---

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Allowed Telegram user IDs (comma-separated numeric ids)
ALLOWED_USERS=123456789

# --- Recommended daily-driver (trusted machine only) ---
# --dangerously-skip-permissions lets Claude act without local confirmation;
# only use it when ALLOWED_USERS is locked to you on a machine you trust.
# CLAUDE_COMMAND=IS_SANDBOX=1 claude --dangerously-skip-permissions
# MONITOR_POLL_INTERVAL=1.0
# CC_TELEGRAM_BROWSE_ROOT=~/dev

# --- Optional: voice-note transcription ---
# Required for voice ONLY. The transcription model is hardcoded to
# gpt-4o-transcribe, so the backend must expose that exact model name.
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- Optional: output verbosity default for users with no /settings choice ---
# verbose | standard | compact | quiet  (default: standard)
# CC_TELEGRAM_VERBOSITY=standard

# --- Optional: other defaults (rarely changed) ---
# TMUX_SESSION_NAME=cc-telegram
# CLAUDE_COMMAND=claude
# MONITOR_POLL_INTERVAL=2.0
